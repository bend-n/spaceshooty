; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

_global_script_classes=[ {
"base": "Enemy",
"class": "Boss",
"language": "GDScript",
"path": "res://Boss.gd"
}, {
"base": "Enemy",
"class": "EasyEnemy",
"language": "GDScript",
"path": "res://EasyEnemy.gd"
}, {
"base": "Area2D",
"class": "Enemy",
"language": "GDScript",
"path": "res://EnemyClass.gd"
}, {
"base": "Enemy",
"class": "EnemyMedium",
"language": "GDScript",
"path": "res://Enemy.gd"
}, {
"base": "Enemy",
"class": "EnemyUfo",
"language": "GDScript",
"path": "res://UFO.gd"
}, {
"base": "Enemy",
"class": "HardEnemy",
"language": "GDScript",
"path": "res://HardEnemy.gd"
}, {
"base": "KinematicBody2D",
"class": "playerkinematic",
"language": "GDScript",
"path": "res://Ship.gd"
}, {
"base": "Node",
"class": "playerstatz",
"language": "GDScript",
"path": "res://playerstats.gd"
} ]
_global_script_class_icons={
"Boss": "",
"EasyEnemy": "",
"Enemy": "",
"EnemyMedium": "",
"EnemyUfo": "",
"HardEnemy": "",
"playerkinematic": "",
"playerstatz": ""
}

[application]

config/name="Space Shooter"
run/main_scene="res://StartMenu.tscn"
boot_splash/image="res://icon.png"
boot_splash/use_filter=false
config/icon="res://icon.png"
config/macos_native_icon="res://icon.png"
config/windows_native_icon="res://icon.png"

[autoload]

Music="*res://Music.tscn"
SaveAndLoad="*res://Save&Load.gd"
enemy_damage="*res://enemy_damage.gd"
playerstats="*res://playerstats.gd"
Shake="*res://shake.gd"

[display]

window/size/width=320
window/size/height=180
window/size/test_width=1280
window/size/test_height=720
window/dpi/allow_hidpi=true
window/vsync/use_vsync=false
window/per_pixel_transparency/allowed=true
window/per_pixel_transparency/enabled=true
window/stretch/mode="2d"
window/stretch/aspect="keep"

[importer_defaults]

texture={
"compress/bptc_ldr": 0,
"compress/hdr_mode": 0,
"compress/lossy_quality": 0.7,
"compress/mode": 0,
"compress/normal_map": 0,
"detect_3d": false,
"flags/anisotropic": false,
"flags/filter": false,
"flags/mipmaps": false,
"flags/repeat": 0,
"flags/srgb": 2,
"process/HDR_as_SRGB": false,
"process/fix_alpha_border": true,
"process/invert_color": false,
"process/normal_map_invert_y": false,
"process/premult_alpha": false,
"size_limit": 0,
"stream": false,
"svg/scale": 1.0
}

